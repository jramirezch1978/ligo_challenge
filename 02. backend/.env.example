# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# Zona horaria (America/Lima, UTC-5). Debe coincidir con la de la base de
# datos (ver 03. database/deploy.bat, flags -c timezone / -c log_timezone).
TZ=America/Lima

# PostgreSQL
# NOTE: 5434 is the HOST port published by "03. database\deploy.bat" (mapped to
# the container's internal 5432) to avoid clashing with other local Postgres instances.
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=ligo
DATABASE_PASSWORD=ligo_password
DATABASE_NAME=wallet_service
DATABASE_SSL=false

# JWT (mock login)
JWT_SECRET=change-this-super-secret-key-in-production
JWT_EXPIRES_IN=3600

# Mock authentication credentials (simulated login, no real user store).
# ADMIN: back-office/service account, can operate any wallet.
AUTH_MOCK_USERNAME=senior.backend
AUTH_MOCK_PASSWORD=Password123

# CUSTOMER: scoped to a single wallet owner (see 03. database seed data).
# Used to exercise the 403 Forbidden ownership rule (WalletAccessService):
# this identity can only operate wallets whose ownerName matches AUTH_CUSTOMER_OWNER_NAME.
AUTH_CUSTOMER_USERNAME=juan.perez
AUTH_CUSTOMER_PASSWORD=Cliente123
AUTH_CUSTOMER_OWNER_NAME=Juan Perez
