{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "src/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": ["src/**/*.(t|j)s", "!src/**/*.module.ts", "!src/main.ts", "!src/database/migrations/**"],
  "coverageDirectory": "./coverage"
}
