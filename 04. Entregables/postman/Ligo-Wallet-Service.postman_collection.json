            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{walletId1}}\",\n  \"type\": \"DEBIT\",\n  \"amount\": \"5.00\",\n  \"currency\": \"PEN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "[Idempotencia] Misma Idempotency-Key + mismo body -> misma respuesta exacta (201, sin reprocesar)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response body is IDENTICAL to the first call (replay, not reprocessed)', () => {",
                  "  pm.expect(pm.response.text()).to.eql(pm.collectionVariables.get('idempotentFirstResponse'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "fixed-demo-key-001" }
