    {
      "name": "Reglas de negocio - Transacciones (atomicidad e idempotencia)",
      "description": "Un request por cada regla crítica de TRANSACCIONES del challenge: atomicidad/rollback (cubierto por tests automatizados, ver README), idempotencia exacta, conflicto por payload distinto, y no reversar dos veces.",
      "item": [
        {
          "name": "[Idempotencia] Primera llamada con Idempotency-Key nueva (201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('idempotentFirstResponse', pm.response.text());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "fixed-demo-key-001" }
