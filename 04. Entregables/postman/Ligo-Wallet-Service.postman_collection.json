{
  "info": {
    "name": "Ligo Wallet Transaction Service",
    "description": "Colección Postman para el Wallet Transaction Service (Ligo - Backend Senior Technical Challenge). Cada carpeta 'Reglas de negocio' contiene un request por cada regla crítica de wallet/transacciones exigida por el challenge, con scripts pm.test ejecutables (Collection Runner) que verifican el código HTTP esperado, no solo inspección manual.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "walletId1", "value": "wal_001" },
    { "key": "walletId2", "value": "wal_002" },
    { "key": "usdWalletId", "value": "wal_003" },
    { "key": "blockedWalletId", "value": "wal_004" },
    { "key": "transactionId", "value": "" },
    { "key": "reversalTransactionId", "value": "" },
    { "key": "idempotentFirstResponse", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns a JWT token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"senior.backend\",\n  \"password\": \"Password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (CUSTOMER, owns wal_001 only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns a JWT token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.collectionVariables.set('customerToken', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"juan.perez\",\n  \"password\": \"Cliente123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "[Seguridad] Login with invalid credentials (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 401', () => pm.response.to.have.status(401));"]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"senior.backend\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "[Seguridad] Login with malformed payload, missing password (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 400', () => pm.response.to.have.status(400));"]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"senior.backend\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Wallets",
      "item": [
        {
          "name": "List accessible wallets (ADMIN sees all)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns an array with more than one wallet', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  pm.expect(body.length).to.be.greaterThan(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/wallets/list", "host": ["{{baseUrl}}"], "path": ["wallets", "list"] }
          }
        },
        {
          "name": "List accessible wallets (CUSTOMER sees only own wallets)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Every wallet belongs to Juan Perez', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.every((w) => w.ownerName === 'Juan Perez')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/wallets/list", "host": ["{{baseUrl}}"], "path": ["wallets", "list"] }
          }
        },
        {
          "name": "Get balance",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallets/balance?walletId={{walletId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "balance"],
              "query": [{ "key": "walletId", "value": "{{walletId1}}" }]
            }
          }
        },
        {
          "name": "[Seguridad] Get balance without token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 401', () => pm.response.to.have.status(401));"]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallets/balance?walletId={{walletId1}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "balance"],
              "query": [{ "key": "walletId", "value": "{{walletId1}}" }]
            }
          }
        },
        {
          "name": "[Seguridad] Get balance of another owner's wallet with customer token (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 403', () => pm.response.to.have.status(403));"]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallets/balance?walletId={{walletId2}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "balance"],
              "query": [{ "key": "walletId", "value": "{{walletId2}}" }]
            }
          }
        },
        {
          "name": "Get movements (paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallets/movements?walletId={{walletId1}}&type=ALL&status=COMPLETED&page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "movements"],
              "query": [
                { "key": "walletId", "value": "{{walletId1}}" },
                { "key": "type", "value": "ALL" },
                { "key": "status", "value": "COMPLETED" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "[Seguridad] List movements of another owner's wallet with customer token (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 403', () => pm.response.to.have.status(403));"]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/wallets/movements?walletId={{walletId2}}",
              "host": ["{{baseUrl}}"],
              "path": ["wallets", "movements"],
              "query": [{ "key": "walletId", "value": "{{walletId2}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create debit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Transaction is COMPLETED', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('COMPLETED');",
                  "  pm.collectionVariables.set('transactionId', body.transactionId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{walletId1}}\",\n  \"type\": \"DEBIT\",\n  \"amount\": \"25.50\",\n  \"currency\": \"PEN\",\n  \"description\": \"Pago QR comercio\",\n  \"externalReference\": \"qr_789456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Create credit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 201', () => pm.response.to.have.status(201));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{walletId1}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": \"50.00\",\n  \"currency\": \"PEN\",\n  \"description\": \"Abono manual\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Transfer between wallets",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Type is TRANSFER', () => pm.expect(pm.response.json().type).to.eql('TRANSFER'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceWalletId\": \"{{walletId1}}\",\n  \"targetWalletId\": \"{{walletId2}}\",\n  \"amount\": \"100.00\",\n  \"currency\": \"PEN\",\n  \"description\": \"Transferencia entre usuarios\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/transfer",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "transfer"]
            }
          }
        },
        {
          "name": "Reverse a transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Type is REVERSAL', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.type).to.eql('REVERSAL');",
                  "  pm.collectionVariables.set('reversalTransactionId', body.transactionId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"reason\": \"Merchant refund / reversal\",\n  \"externalReference\": \"rev_123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/reversal",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "reversal"]
            }
          }
        },
        {
          "name": "Get transaction status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status code is 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions/status?transactionId={{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "status"],
              "query": [{ "key": "transactionId", "value": "{{transactionId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Reglas de negocio - Wallet",
