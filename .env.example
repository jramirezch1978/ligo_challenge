# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# PostgreSQL
# NOTE: 5434 is the HOST port published by docker-compose.yml (mapped to the
# container's internal 5432) to avoid clashing with other local Postgres instances.
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=ligo
DATABASE_PASSWORD=ligo_password
DATABASE_NAME=wallet_service
DATABASE_SSL=false

# JWT (mock login)
JWT_SECRET=change-this-super-secret-key-in-production
JWT_EXPIRES_IN=3600

# Mock authentication credentials (simulated login, no real user store)
AUTH_MOCK_USERNAME=senior.backend
AUTH_MOCK_PASSWORD=Password123
