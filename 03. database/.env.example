# Credenciales del contenedor PostgreSQL 17 (capa de base de datos)
POSTGRES_USER=ligo
POSTGRES_PASSWORD=ligo_password
POSTGRES_DB=wallet_service

# Puerto publicado en el host (5434 para no chocar con otra instancia local en 5432)
HOST_PORT=5434

# Nombres de recursos Docker
NETWORK_NAME=ligo-network
CONTAINER_NAME=ligo-wallet-postgres
VOLUME_NAME=ligo-wallet-pgdata
